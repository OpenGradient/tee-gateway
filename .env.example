# API keys for LLM providers.
# Copy this file to .env and fill in your keys before running run-enclave.sh.
# The .env file is read once by run-enclave.sh and injected into the enclave
# via POST /v1/keys. Keys are never baked into the Docker image, keeping
# PCR measurements stable across deployments.

OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Blockchain heartbeat configuration (optional).
# If HEARTBEAT_CONTRACT_ADDRESS and HEARTBEAT_FACILITATOR_URL are set, the enclave
# signs heartbeat payloads and the facilitator relays on-chain txs.
HEARTBEAT_CONTRACT_ADDRESS=
HEARTBEAT_FACILITATOR_URL=
TEE_HEARTBEAT_INTERVAL=900
